<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".MovieTicketApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Firebase">

        <receiver
            android:name=".notifications.ReminderReceiver"
            android:enabled="true"
            android:exported="false" />

        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".MainActivity" android:exported="false" />
        <activity android:name=".activities.MoviesListActivity" android:exported="false" />
        <activity android:name=".activities.MovieDetailActivity" android:exported="false" />
        <activity android:name=".activities.SeatSelectionActivity" android:exported="false" />
        <activity android:name=".activities.TicketConfirmationActivity" android:exported="false" />

        <activity android:name=".TheaterActivity" android:exported="false" />
        <activity android:name=".MovieActivity" android:exported="false" />
        <activity android:name=".ShowtimeActivity" android:exported="false" />
        <activity android:name=".SeatActivity" android:exported="false" />
        <activity android:name=".TicketDetailActivity" android:exported="false" />
    </application>

</manifest>